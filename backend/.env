# ─────────────────────────────────────────────────────────────
#  AI Internship Allocation & Recommendation System
#  .env — Environment Configuration
#  ⚠️  NEVER commit this file to GitHub / public repos!
# ─────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────
PORT=5001
NODE_ENV=development

# ── MongoDB ──────────────────────────────────────────────────
# Replace <username>, <password>, <cluster> with your Atlas values
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/aiinternship?retryWrites=true&w=majority

# ── JWT ──────────────────────────────────────────────────────
# Use a long, random string in production — NEVER use a short/guessable value
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET_MIN_32_CHARS
JWT_EXPIRE=7d

# ── Default Admin Credentials (used by seed script only) ─────
ADMIN_NAME=Administrator
ADMIN_EMAIL=admin@aiias.edu
# IMPORTANT: Change this immediately after first login
ADMIN_PASSWORD=Admin@1234

# ── File Uploads ─────────────────────────────────────────────
UPLOAD_PATH=uploads
MAX_FILE_SIZE_MB=5

# ── CORS — Frontend origin ───────────────────────────────────
CLIENT_ORIGIN=https://riyapawar2338.github.io